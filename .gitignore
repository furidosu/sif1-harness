# Decrypted/decompiled client assets (KLab proprietary — never commit)
assets/decrypted/
assets/decompiled/

# Local checkouts of NPPS4 + DLAPI (clone or symlink here for the
# priors extractor; never commit)
/npps4
/npps4-dlapi

# Per-run trace outputs (regenerated by harness)
build/runtime/

# Pre-merge classification snapshot. Always derivable from a fresh
# pipeline run; only the canonical post-merge coverage_classification.*
# is committed as the baseline.
build/coverage_classification_initial.*

# Python caches
__pycache__/
*.pyc
.venv/
.uv/
*.egg-info/

# Editor cruft
.DS_Store
.vscode/
.idea/

# Reports generated locally
report.md
*.local.md

# Local working plan. The hard-won priors + gotchas are extracted into
# docs/PRIORS.md and stay committed; PLAN.md keeps the rotting stage-by-
# stage scaffolding and decision-point scratchwork out of the repo.
PLAN.md
